{
  "compilerOptions": {
    "target": "ES2020",

    // ✅ MUST MATCH
    "module": "Node16",
    "moduleResolution": "node16",

    "ignoreDeprecations": "6.0",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}